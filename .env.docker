# ShrikDB Docker Environment Configuration
# Copy this file to .env and customize as needed

# ShrikDB Engine Configuration
SHRIKDB_HOST=shrikdb
SHRIKDB_PORT=8080
WAL_SYNC_MODE=fsync

# Backend API Configuration
API_PORT=3001
WS_PORT=3002

# Frontend Configuration
FRONTEND_PORT=3000

# Logging
LOG_LEVEL=info

# Node Environment
NODE_ENV=production
